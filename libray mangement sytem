SELECT * FROM Members;

SELECT * FROM Books;

SELECT Books.BookID, Books.Title, Authors.AuthorName, Books.Category
FROM Books
JOIN Authors ON Books.AuthorID = Authors.AuthorID;

SELECT IssueBook.IssueID, Members.FullName, Books.Title,
IssueBook.IssueDate, IssueBook.DueDate, IssueBook.ReturnDate
FROM IssueBook
JOIN Members ON IssueBook.MemberID = Members.MemberID
JOIN Books ON IssueBook.BookID = Books.BookID;

SELECT Members.FullName, Books.Title, IssueBook.DueDate
FROM IssueBook
JOIN Members ON IssueBook.MemberID = Members.MemberID
JOIN Books ON IssueBook.BookID = Books.BookID
WHERE ReturnDate IS NULL;

SELECT COUNT(*) AS TotalBooks FROM Books;

SELECT COUNT(*) AS TotalMembers FROM Members;

